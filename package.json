{
  "name": "workspace-runner",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "orchestrator:install": "npm --prefix ./.ai/runtime ci",
    "orchestrator:run:example": "npm --prefix ./.ai/runtime run start:example",
    "dev:web": "npm --prefix ./apps/web run dev",
    "dev:web:reset": "npm --prefix ./apps/web run dev:reset",
    "build:web": "npm --prefix ./apps/web run build",
    "build": "npm run build:web",
    "lint": "npm --prefix ./apps/web run lint",
    "test:server": "./scripts/run-gradle-java21.sh test",
    "run:server": "./scripts/run-server-local.sh",
    "check:e2e-ready": "npm run test:server && npm run build:web",
    "preflight": "./scripts/preflight.sh",
    "init:env": "./scripts/init-env.sh",
    "ready:local": "npm run preflight && npm run check:e2e-ready",
    "health:check": "curl -sS http://localhost:8080/health",
    "smoke:server": "./scripts/smoke-server.sh",
    "smoke:interview-flow": "./scripts/smoke-interview-flow.sh",
    "smoke:interview-flow:luna": "./scripts/smoke-interview-flow.sh http://localhost:8080 test-key luna",
    "smoke:interview-flow:jet": "./scripts/smoke-interview-flow.sh http://localhost:8080 test-key jet",
    "smoke:interview-flow:iron": "./scripts/smoke-interview-flow.sh http://localhost:8080 test-key iron",
    "smoke:interview-end": "./scripts/smoke-interview-end.sh",
    "smoke:interview-complete": "./scripts/smoke-interview-complete.sh",
    "smoke:history-guards": "./scripts/smoke-history-guards.sh",
    "smoke:all": "npm run smoke:server && npm run smoke:interview-flow && npm run smoke:interview-end && npm run smoke:interview-complete && npm run smoke:history-guards",
    "smoke:all:local": "./scripts/smoke-all-local.sh"
  }
}
